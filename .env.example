# ===========================================
# Servidor
# ===========================================
PORT=3003
NODE_ENV=development

# ===========================================
# Banco de Dados (MySQL)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=erp_financeiro

# Alternativas locais (fallback)
# DB_HOST_LOCAL=localhost
# DB_USERNAME_LOCAL=root
# DB_PASSWORD_LOCAL=

# Sincronizacao automatica das entities (apenas desenvolvimento)
DB_SYNC=false
# Log de queries SQL
DB_LOGGING=true

# Senha para endpoint de reset do banco (seguranca)
# DB_RESET_PASSWORD=

# ===========================================
# Autenticacao (JWT)
# ===========================================
JWT_SECRET=sua-chave-secreta-aqui
JWT_SECONDS_EXPIRE=86400

# ===========================================
# Email (SMTP)
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_SERVICE=gmail
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seu-email@gmail.com
MAIL_PASS=sua-senha-de-app
MAIL_REPLY=noreply@seudominio.com

# ===========================================
# URLs da Aplicacao
# ===========================================
FRONT_APP_URL=http://localhost:3000
HOST_APP_URL=http://localhost:3003
LOGO_URL=https://your-storage-url.com/Logo.png

# ===========================================
# Integracao Bradesco (opcional)
# ===========================================
# BRADESCO_BASE_URL=
# BRADESCO_CLIENT_KEY=
# BRADESCO_CLIENT_SECRET=
# BRADESCO_PUBLIC_KEY=
# BRADESCO_PRIVATE_KEY=
# BRADESCO_CA_BASE64=

# ===========================================
# SSH/SFTP - VAN Bradesco (opcional)
# ===========================================
# SSH_HOST=
# SSH_PORT=22
# SSH_USERNAME=
# SSH_PASSWORD=

# Caminhos STCPCLT (opcional, tem defaults)
# STCPCLT_SAIDA_PATH=C:\STCPCLT_BRADESCO\O0055BRADESCO\SAIDA
# STCPCLT_ENTRADA_PATH=C:\STCPCLT_BRADESCO\O0055BRADESCO\ENTRADA
# STCPCLT_EXE_PATH=C:\STCPCLT_BRADESCO\program\stcpclt.exe
# STCPCLT_INI_PATH=C:\STCPCLT_BRADESCO\CTCP.INI
# STCPCLT_PROFILE=O0055BRADESCO

# ===========================================
# CNAB (opcional)
# ===========================================
# EMPRESA_NUM_INSC=
# CONVENIO=
# NOME_BANCO=BANCO BRADESCO S.A.

# ===========================================
# Dados de Seed/Import (opcional, tem defaults)
# ===========================================
# DEFAULT_IMPORT_CPF=00000000000
# DEFAULT_IMPORT_EMAIL=admin@example.com
# DEFAULT_IMPORT_NAME=Admin
# DEFAULT_IMPORT_PASSWORD=changeme
# DEFAULT_IMPORT_PHONE=0000000000
# DEFAULT_SUPPLIER_CNPJ=00000000000000
